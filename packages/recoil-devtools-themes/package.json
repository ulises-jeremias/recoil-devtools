{
  "name": "recoil-devtools-themes",
  "version": "1.1.0",
  "description": "Color themes for Recoil DevTools monitors",
  "license": "MIT",
  "author": "ulises-jeremias <ulisescf.24@gmail.com>",
  "homepage": "https://github.com/ulises-jeremias/recoil-devtools/tree/main/packages/recoil-devtools-themes#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ulises-jeremias/recoil-devtools.git",
    "directory": "packages/recoil-devtools-themes"
  },
  "bugs": {
    "url": "https://github.com/ulises-jeremias/recoil-devtools/issues"
  },
  "keywords": [
    "recoil",
    "themes",
    "devtools",
    "base16",
    "recoil-devtools"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist coverage"
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "dependencies": {
    "base16": "^1.0.0"
  },
  "devDependencies": {
    "@types/base16": "^1.0.5",
    "@types/react": "^19.2.17",
    "eslint": "^9.39.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
