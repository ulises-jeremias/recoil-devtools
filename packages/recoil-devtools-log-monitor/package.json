{
  "name": "recoil-devtools-log-monitor",
  "version": "1.0.0",
  "description": "Recoil log monitor — visual state and action history with time-travel",
  "license": "MIT",
  "author": "ulises-jeremias <ulisescf.24@gmail.com>",
  "homepage": "https://github.com/ulises-jeremias/recoil-devtools/tree/main/packages/recoil-devtools-log-monitor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ulises-jeremias/recoil-devtools.git",
    "directory": "packages/recoil-devtools-log-monitor"
  },
  "bugs": {
    "url": "https://github.com/ulises-jeremias/recoil-devtools/issues"
  },
  "keywords": [
    "recoil",
    "log-monitor",
    "devtools",
    "recoil-devtools",
    "react",
    "state-management",
    "time-travel"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist coverage"
  },
  "peerDependencies": {
    "react": ">=17",
    "recoil": ">=0.7.0"
  },
  "dependencies": {
    "base16": "^1.0.0",
    "lodash-es": "^4.17.21",
    "react-json-tree": "^0.19.0",
    "recoil-devtools-themes": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/base16": "^1.0.2",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recoil": "^0.7.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
